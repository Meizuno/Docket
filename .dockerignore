# Keep the build context small and free of host-only artifacts.
# NOTE: README.md and pyproject.toml are required by the build — do not ignore.

.git
.github
.claude

# Virtual environments
.venv
venv
env
ENV

# Python caches / build artifacts
__pycache__
*.py[cod]
*.egg-info
*.egg
build
dist
uv.lock

# Tooling caches
.pytest_cache
.mypy_cache
.ruff_cache

# Tests are not needed in the runtime image
tests

# Secrets / local config
.env
.env.*

# Local databases / logs
*.db
*.sqlite
*.sqlite3
*.log
